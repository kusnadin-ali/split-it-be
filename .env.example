# Copy file ini ke .env dan isi dengan nilai yang sesuai
# cp .env.example .env

PORT=8080
ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/splitit?sslmode=disable

# JWT — ganti dengan string random yang panjang di production!
# Bisa generate dengan: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
